{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Backend (Spring Boot)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cd backend && mvnw spring-boot:run"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Start Frontend (Vite)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "cd frontend && npm run dev"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Start Full Stack (Backend + Frontend)",
            "dependsOn": [
                "Start Backend (Spring Boot)",
                "Start Frontend (Vite)"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}